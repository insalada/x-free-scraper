# ──────────────────────────────────────────────────────────────────────────────
# x-free-scraper — environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Session ───────────────────────────────────────────────────────────────────
# Path where the Playwright session cookies are stored.
# Default: x_session.json in the project root.
# SESSION_STORAGE_PATH=x_session.json

# ── Scraper behaviour ─────────────────────────────────────────────────────────
# How many hours back to look for posts (used when --hours is not passed).
# HOURS_LOOKBACK=24

# Run the browser in headless mode (true) or with a visible window (false).
# SCRAPER_HEADLESS=true

# ── Fallback credentials ──────────────────────────────────────────────────────
# Only used when no session file exists. Prefer refresh_session() instead.
# X_USERNAME=your_x_username
# X_EMAIL=your_email@example.com
# X_PASSWORD=your_password
